<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AneDoces.App.Pages.CadastrarOrcamentoPage"
             Title="Cadastrar Orçamento"
             BackgroundColor="#F8F2EC">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">

            <Label Text="Novo Orçamento"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#5A2E1F" />

            <Label Text="Cadastre um orçamento para um cliente"
                   FontSize="14"
                   TextColor="#A67B5B" />

            <Frame BackgroundColor="White"
                   BorderColor="#F0E0D6"
                   CornerRadius="20"
                   Padding="16">

                <VerticalStackLayout Spacing="12">

                    <Picker x:Name="ClientePicker"
                            Title="Selecione o cliente"
                            TitleColor="#A67B5B"
                            TextColor="#5A2E1F" />

                    <Editor x:Name="DescricaoEditor"
                            Placeholder="Descrição do orçamento"
                            AutoSize="TextChanges"
                            HeightRequest="120"
                            TextColor="#5A2E1F" />

                    <Entry x:Name="ValorEntry"
                           Placeholder="Valor"
                           Keyboard="Numeric"
                           TextColor="#5A2E1F" />

                    <Button Text="Salvar Orçamento"
                            BackgroundColor="#6B3E2E"
                            TextColor="White"
                            CornerRadius="18"
                            Clicked="OnSalvarOrcamentoClicked" />

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>